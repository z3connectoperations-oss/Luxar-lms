{
  "name": "@luxar/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply luxar-lms --local",
    "migrate:remote": "wrangler d1 migrations apply luxar-lms --remote",
    "seed:local": "wrangler d1 execute luxar-lms --local --file=./seed.sql"
  },
  "dependencies": {
    "@luxar/db": "*",
    "@luxar/shared": "*",
    "drizzle-orm": "^0.38.3",
    "hono": "^4.6.14",
    "jose": "^5.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "wrangler": "^4.0.0"
  }
}
